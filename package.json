{
  "name": "nerimity-discord-bridge",
  "version": "1.0.0",
  "description": "Bot passerelle bidirectionnel entre Nerimity et Discord (texte + voix)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "dependencies": {
    "discord.js": "14.16.3",
    "@discordjs/voice": "0.18.0",
    "@discordjs/opus": "^0.9.0",
    "socket.io-client": "^4.7.4",
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "winston": "^3.11.0",
    "sodium-native": "^4.1.1",
    "prism-media": "^1.3.5"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.11.5"
  }
}
